@startuml

' Classe Categoria
class Categoria {
  -id: int
  -nome: String
  -descricao: String
}

' Classe Trilha
class Trilha {
  -id: int
  -nome: String
  -descricao: String
  -categoria: Categoria
  -modulos: ArrayList<Modulo>
  -conquistas: ArrayList<Conquista>
}

' Classe Modulo
class Modulo {
  -id: int
  -titulo: String
  -trilha: Trilha
  -ordem: int
  -conteudo: String
}

' Classe Conquista
class Conquista {
  -id: int
  -nome: String
  -descricao: String
  -tipo: TipoConquista
  -xpGanho: int
}

' Enum para o tipo de conquista
enum TipoConquista {
  MODULOS_CONCLUIDOS
  HORAS_ESTUDADAS
  CONCLUSAO_TRILHA
  CONQUISTA_ESPECIAL
}

' Relacionamentos
Trilha "1" --> "1" Categoria : pertence >
Trilha "1" --> "0..*" Modulo : contém >
Trilha "1" --> "0..*" Conquista : contém >
Modulo "1" --> "1" Trilha : pertence >

@enduml